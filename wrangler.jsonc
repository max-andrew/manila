{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "manila",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // @unlink-xyz/sdk maps its /admin entry to null under browser export
  // conditions (admin keys must not ship to browsers). This is a server-side
  // Worker, so point straight at the module.
  "alias": {
    "@unlink-xyz/sdk/admin": "./node_modules/@unlink-xyz/sdk/dist/admin/index.js"
  },
  "assets": { "directory": "./public", "binding": "ASSETS" },
  // The agent brain runs on Workers AI — no external LLM key. Llama 3.3 (fp8)
  // is the most reliable function-caller of the free models and drives the
  // demo well; @cf/nvidia/nemotron-3-120b-a12b is the alternative to try for
  // richer multi-tool trajectories (same messages+tools API).
  "ai": { "binding": "AI" },
  "vars": { "AGENT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast" },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "manila",
      "database_id": "3d165f7e-4d27-4c95-b62b-0574b3ceface",
      "migrations_dir": "./migrations"
    }
  ],
  "observability": { "enabled": true },
  // The Dynamic MPC signer runs as a Container (native binary can't run in
  // workerd), fronted by the SIGNER Durable Object. Single instance — the MPC
  // session isn't concurrency-safe. basic = 1 GiB (256 MiB risks OOM with the
  // SDK). Scales to zero (sleepAfter in signer-container.ts); woken on demand.
  "containers": [
    {
      "class_name": "SignerContainer",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "SIGNER", "class_name": "SignerContainer" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["SignerContainer"] }]
}
